environment:
 
hooks:
    enabled: false
    active: NEVER
    command:
        enabled: false
        active: NEVER
    jbang:
        enabled: false
        active: NEVER
    script:
        enabled: false
        active: NEVER
 
project:
    name: JairoSVG
    version: 1.0.13
    versionPattern: SEMVER
    snapshot:
        enabled: false
        pattern: .*-SNAPSHOT
        label: early-access
        fullChangelog: false
    description: SVG 1.1 to PNG, JPEG, TIFF, PDF, PS/EPS, and SVG converter powered by Java2D
    longDescription: JairoSVG is a pure Java SVG 1.1 renderer using Java2D. It converts SVG files
to PNG, JPEG, TIFF, PDF, PostScript, EPS, and SVG formats. Designed for
simplicity and performance, JairoSVG delivers fast rendering without
requiring any native dependencies.

    license: MIT
    inceptionYear: 2024
    copyright: 2024 Bruno Borges
    authors:
        Bruno Borges
    tags:
        java
        svg
        png
        pdf
        converter
        java2d
    stereotype: NONE
    links:
        homepage: https://github.com/brunoborges/jairosvg
        documentation: https://github.com/brunoborges/jairosvg
        license: https://spdx.org/licenses/MIT.html
        bugTracker: https://{{repoHost}}/{{repoOwner}}/{{repoName}}/issues
        vcsBrowser: https://{{repoHost}}/{{repoOwner}}/{{repoName}}
    extraProperties:
        versionMajor: 1
        versionMinor: 0
        versionPatch: 13
        versionNumber: 1.0.13
        versionWithUnderscores: 1_0_13
        versionWithDashes: 1-0-13
        versionNumberWithUnderscores: 1_0_13
        versionNumberWithDashes: 1-0-13
        effectiveVersionWithUnderscores: 1_0_13
        effectiveVersionWithDashes: 1-0-13
    languages:
        java:
            enabled: true
            groupId: io.brunoborges
            artifactId: jairosvg
            jvmOptions:
            environmentVariables:
            multiProject: false
 
platform:
 
release:
    github:
        enabled: true
        host: github.com
        owner: brunoborges
        name: jairosvg
        username: brunoborges
        token: ************
        artifacts: true
        files: true
        checksums: true
        catalogs: true
        signatures: true
        repoUrl: https://{{repoHost}}/{{repoOwner}}/{{repoName}}
        repoCloneUrl: https://{{repoHost}}/{{repoOwner}}/{{repoName}}.git
